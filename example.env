# Copy this file to `.env` in the repository root and adjust values.
# Load order: `flask_app.py` uses python-dotenv (see `load_dotenv`).
#
# Paths for LINEAR_RAG_* are relative to the current working directory when you
# start the backend; run `python flask_app.py` from the repo root so `data`
# and `LinearRAG` resolve correctly.

# --- LinearRAG ---
LINEAR_RAG_DATA_DIR=data
LINEAR_RAG_ROOT=LinearRAG
LINEAR_RAG_WORKING_DIR=LinearRAG/import
LINEAR_RAG_DATASET_NAME=oversight_data
LINEAR_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
LINEAR_RAG_SPACY_MODEL=en_core_web_sm
LINEAR_RAG_MAX_WORKERS=1

# --- Query decomposition agent (OpenAI-compatible API, e.g. vLLM) ---
LOCAL_AGENT_ENABLED=true
LOCAL_AGENT_DEBUG=true
QUERY_DECOMPOSITION_AGENT_MODE=local
LOCAL_AGENT_LLM_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_AGENT_LLM_MODEL=Qwen/Qwen3-8B-Instruct
LOCAL_AGENT_LLM_API_KEY=local-dev-key
LOCAL_AGENT_LLM_TIMEOUT_SECONDS=20

# --- Optional rerank ---
OVERSIGHT_RERANK_ENABLED=true
OVERSIGHT_RERANK_MODEL=BAAI/bge-reranker-base
OVERSIGHT_RERANK_FP16=true
OVERSIGHT_RERANK_MAX_INPUT=60

# --- Backend ---
FLASK_PORT=5001

# --- Frontend (export when running `npm run dev` under frontend/) ---
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:5001
